rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/settings/{document=**} {
      function ownsSettings() {
        return request.auth != null && request.auth.uid == userId;
      }

      function usesCurrentWriterProtocol() {
        return request.resource.data.minimumWriterBuild is int
          && request.resource.data.writerBuildNumber is int
          && request.resource.data.writeId is string
          && request.resource.data.writeId != resource.data.writeId
          && request.resource.data.writerBuildNumber >= resource.data.minimumWriterBuild
          && request.resource.data.minimumWriterBuild >= resource.data.minimumWriterBuild;
      }

      allow read: if ownsSettings();
      allow create: if ownsSettings();
      allow update: if ownsSettings()
        && (!('minimumWriterBuild' in resource.data) || usesCurrentWriterProtocol());
    }
  }
}
